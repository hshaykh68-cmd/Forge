    <!-- ================================================================ -->
    <string name="permission_alarm_title">Alarm Permission Required</string>
    <string name="permission_alarm_description">WakeForge needs permission to schedule exact alarms. Without this, alarms may not ring at the exact time you set.</string>
    <string name="permission_notification_title">Notification Permission</string>
    <string name="permission_notification_description">Notifications are needed to show alarm reminders and upcoming alarm alerts.</string>
    <string name="permission_battery_title">Battery Optimization</string>
    <string name="permission_battery_description">To ensure alarms ring reliably, please disable battery optimization for WakeForge.</string>
    <string name="permission_dnd_title">Do Not Disturb Access</string>
    <string name="permission_dnd_description">WakeForge needs Do Not Disturb access to override silent mode and ring alarms when you need them.</string>
    <string name="permission_activity_title">Activity Recognition</string>
    <string name="permission_activity_description">Step Challenge missions require activity recognition to count your steps.</string>
    <string name="permission_overlay_title">Display Over Other Apps</string>
    <string name="permission_overlay_description">WakeForge needs to display the alarm screen over other apps to ensure you see and respond to alarms.</string>
